# ── App ───────────────────────────────────────────────────────
APP_KEY=                          # php artisan key:generate
APP_URL=https://tpl.pedrosmaia.com

# ── Ports ─────────────────────────────────────────────────────
FRONTEND_PORT=80

# ── Database ──────────────────────────────────────────────────
DB_DATABASE=ptl
DB_USERNAME=ptl
DB_PASSWORD=                      # Generate: openssl rand -base64 32
DB_ROOT_PASSWORD=                 # Generate: openssl rand -base64 32

# ── API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                # For roadmap generation (optional)
ADMIN_API_KEY=                    # Generate: openssl rand -hex 32
ADMIN_EMAILS=                     # Comma-separated emails for Filament admin
