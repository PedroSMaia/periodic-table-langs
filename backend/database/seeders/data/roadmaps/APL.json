{"language": "APL", "core": [{"id": "core-1", "label": "APL", "description": "Array-oriented notation with special symbols.", "topics": [{"id": "core-1-1", "label": "APL Environment", "description": "Install Dyalog APL or use TryAPL online. APL uses special Unicode symbols as operators.", "type": "required", "resources": ["https://tryapl.org/", "https://www.dyalog.com/"]}, {"id": "core-1-2", "label": "Arrays & Scalars", "description": "Everything is an array. Scalars are 0-dimensional arrays. Reshape with \u2374.", "type": "required", "resources": ["https://tryapl.org/", "https://aplwiki.com/"]}, {"id": "core-1-3", "label": "Primitive Functions", "description": "+  -  \u00d7  \u00f7  \u2308  \u230a  |  *  \u235f  \u25cb  !  ?  ~ \u2014 all work on arrays element-wise.", "type": "required", "resources": ["https://tryapl.org/", "https://aplwiki.com/"]}, {"id": "core-1-4", "label": "Operators", "description": "/ (reduce), \\ (scan), \u00a8 (each), \u2368 (commute). Operators modify functions.", "type": "required", "resources": ["https://tryapl.org/", "https://aplwiki.com/"]}, {"id": "core-1-5", "label": "Dfns (Functions)", "description": "Define functions with {\u237a \u2375} syntax. \u2375 is right arg, \u237a is optional left arg.", "type": "required", "resources": ["https://tryapl.org/", "https://aplwiki.com/"]}, {"id": "core-1-6", "label": "Indexing & Selection", "description": "\u2337 for indexing, \u2373 for iota (generate indices), \u220a for membership.", "type": "required", "resources": ["https://tryapl.org/", "https://aplwiki.com/"]}]}], "paths": [{"id": "path-apl-data", "label": "Data Analysis", "icon": "\ud83d\udcca", "category": "Data", "category_icon": "\ud83d\udcca"}, {"id": "path-apl-finance", "label": "Financial Modeling", "icon": "\ud83d\udcb0", "category": "Finance", "category_icon": "\ud83d\udcb0"}]}