{"language": "LaTeX", "core": [{"id": "core-1", "label": "LaTeX Fundamentals", "description": "Professional typesetting for academic and scientific documents.", "topics": [{"id": "core-1-1", "label": "Installation & Overleaf", "description": "Install TeX Live or use Overleaf online. LaTeX produces publication-quality documents.", "type": "required", "resources": ["https://www.latex-project.org/get/", "https://www.overleaf.com/learn"]}, {"id": "core-1-2", "label": "Document Structure", "description": "\\documentclass, preamble, \\begin{document}/\\end{document}. Document classes: article, report, book.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Creating_a_document_in_LaTeX", "https://www.latex-project.org/help/documentation/"]}, {"id": "core-1-3", "label": "Text Formatting", "description": "\\textbf, \\textit, \\emph, font sizes, alignment. Sections with \\section, \\subsection.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Bold%2C_italics_and_underlining", "https://www.latex-project.org/help/documentation/"]}, {"id": "core-1-4", "label": "Mathematics", "description": "Inline ($...$) and display (\\[...\\]) math. Equations, fractions, matrices, symbols.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Mathematical_expressions", "https://en.wikibooks.org/wiki/LaTeX/Mathematics"]}, {"id": "core-1-5", "label": "Tables & Figures", "description": "tabular environment, \\includegraphics, figure/table floats, captions.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Tables", "https://www.overleaf.com/learn/latex/Inserting_Images"]}, {"id": "core-1-6", "label": "Lists & Environments", "description": "itemize, enumerate, description. Custom environments with \\newenvironment.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Lists", "https://www.latex-project.org/help/documentation/"]}, {"id": "core-1-7", "label": "Bibliography (BibTeX)", "description": "Manage references with .bib files and \\cite. BibLaTeX for modern bibliographies.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Bibliography_management_with_bibtex", "https://www.overleaf.com/learn/latex/Bibliography_management_with_biblatex"]}, {"id": "core-1-8", "label": "Packages", "description": "\\usepackage for extending LaTeX. Essential: amsmath, graphicx, hyperref, geometry.", "type": "required", "resources": ["https://www.overleaf.com/learn/latex/Learn_LaTeX_in_30_minutes#Adding_a_Table_of_Contents", "https://ctan.org/"]}]}], "paths": [{"id": "path-beamer", "label": "Beamer (Presentations)", "icon": "\ud83d\udcca", "category": "Presentations", "category_icon": "\ud83d\udcca"}, {"id": "path-tikz", "label": "TikZ (Diagrams)", "icon": "\ud83c\udfa8", "category": "Graphics", "category_icon": "\ud83c\udfa8"}, {"id": "path-latex-thesis", "label": "Thesis Writing", "icon": "\ud83d\udcd6", "category": "Academic", "category_icon": "\ud83d\udcda"}, {"id": "path-latex-cv", "label": "CV/Resume Templates", "icon": "\ud83d\udccb", "category": "Templates", "category_icon": "\ud83d\udcdd"}]}